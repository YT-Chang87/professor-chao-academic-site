---
import BaseLayout from "../../layouts/BaseLayout.astro";
import data from "../../data/site.json";
import { labels, type Lang } from "../../i18n";

export function getStaticPaths() {
  return [{ params: { lang: "zh" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as Lang;
const t = labels[lang];
const profile = data.profile[lang];
const home = `${import.meta.env.BASE_URL}${lang}/`;
---
<BaseLayout lang={lang} title={`${profile.name}｜${profile.title}`} description={profile.bio}>
  <section class="home-hero">
    <div class="hero-copy">
      <div class="eyebrow">{profile.university}</div>
      <h1><span>{profile.name}</span><small>{profile.title}</small></h1>
      <p class="department">{profile.department}</p>
      <p class="tagline">{profile.tagline}</p>
      <div class="hero-actions">
        <a class="button primary" href={`${home}research/`}>{t.explore}<span>→</span></a>
        <a class="button secondary" href={`${home}about/`}>{t.profile}</a>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <img class="hero-photo" src={`${import.meta.env.BASE_URL}images/how-ran-chao.jpg`} alt="" />
      <div class="photo-tint"></div>
      <p>ENVIRONMENT<br />HEALTH<br />RISK ASSESSMENT</p>
    </div>
  </section>

  <section class="intro-band">
    <p>{profile.bio}</p>
    <div><span>01</span><span>Research</span><span>02</span><span>Education</span><span>03</span><span>Impact</span></div>
  </section>

  <section class="home-section">
    <div class="section-heading"><div><span class="eyebrow">Research Focus</span><h2>{t.overview}</h2></div><a href={`${home}research/`}>{t.viewAll} →</a></div>
    <div class="card-grid">
      {data.research.map((item, index) => {
        const content = item[lang];
        return <article class="research-card">
          <span class="card-number">0{index + 1}</span><div class="research-icon" aria-hidden="true">{["◌", "⌁", "◇"][index]}</div>
          <h3>{content.title}</h3><p>{content.summary}</p>
        </article>
      })}
    </div>
  </section>

  <section class="home-section news-preview">
    <div class="section-heading"><div><span class="eyebrow">Updates</span><h2>{t.latest}</h2></div><a href={`${home}news/`}>{t.viewAll} →</a></div>
    {data.news.map((item) => <article class="news-item"><time>{item.date}</time><div><h3>{item[lang].title}</h3><p>{item[lang].summary}</p></div></article>)}
  </section>
</BaseLayout>
